-- AI finds statistics
local function findStat(keys)
    local function scan(obj)
        for _, v in pairs(obj:GetChildren()) do
            if v:IsA("IntValue") or v:IsA("NumberValue") or v:IsA("StringValue") then
                for _, k in pairs(keys) do
                    if string.find(string.lower(v.Name), k) then
                        return v.Value
                    end
                end
            end
        end
    end

    if player:FindFirstChild("leaderstats") then
        local v = scan(player.leaderstats)
        if v ~= nil then return v end
    end

    for _, v in pairs(player:GetDescendants()) do
        if v:IsA("IntValue") or v:IsA("NumberValue") or v:IsA("StringValue") then
            for _, k in pairs(keys) do
                if string.find(string.lower(v.Name), k) then
                    return v.Value
                end
            end
        end
    end

    return nil
end

-- fix nil
local function safe(v, d)
    if v == nil then return d end
    return v
end

-- rank color
local function getRankColor(rank)
    rank = tostring(rank):lower()
    if rank:find("pro") then return "Green/Pro"
    elseif rank:find("elite") then return "Blue/Elite"
    elseif rank:find("master") then return "Purple/Master"
    elseif rank:find("legend") then return "Yellow/Legend"
    else return "White/Noob"
    end
end

-- thanh bar
local function bar(val, max)
    val = tonumber(val) or 0
    max = max or 100
    local p = math.clamp(val / max, 0, 1)
    local b = math.floor(p * 10)
    return string.rep("█", b) .. string.rep("░", 10 - b)
end

-- update function (call now + loop)
local function updateUI()
    local streak = safe(findStat({"streak","win"}), 0)
    local kills  = safe(findStat({"kill"}), 0)
    local rank   = safe(findStat({"rank"}), "N/A")
    local time   = safe(findStat({"time"}), 0)
    local acc    = safe(findStat({"accuracy","acc"}), 0)
    local xp     = safe(findStat({"xp","exp"}), 0)
    local sword  = safe(findStat({"sword","weapon"}), "None")
    local money  = safe(findStat({"money","cash","coin"}), 0)
    local kd     = safe(findStat({"kd","ratio"}), 0)

    -- streak logic
    local streakText = ""
    if tonumber(streak) and streak > 0 then
        streakText = "Streak: "..streak
    else
        streakText = "No Streak (0)"
        streak = 0
    end

    -- notify
    if notify and tonumber(streak) and streak > lastStreak then
        Rayfield:Notify({
            Title = "Streak Up!",
            Content = "Now: "..streak,
            Duration = 3
        })
    end
    lastStreak = tonumber(streak) or 0

    local color = getRankColor(rank)

    -- set label (2 current)
    L1:Set(" Kill: "..kills.."\n"..streakText)
    L2:Set(color.." Rank: "..rank.."\n Time: "..time)
    L3:Set(" Acc: "..acc.."\n XP: "..xp)
    L4:Set(" Sword: "..sword.."\n Money: "..money)
    L5:Set("KD: "..kd.." ["..bar(kd,5).."]\nACC ["..bar(acc,100).."]")
end

