-- NOTIFY
local function Notify(title,p)
    if not AI then return end
    Rayfield:Notify({
        Title = title,
        Content = p.DisplayName.." (@"..p.Name..")",
        Duration = 5
    })
end

-- ESP (10s)
local function ESP(p,color)
    if not p.Character then return end
    local h = Instance.new("Highlight")
    h.FillColor = color
    h.Parent = p.Character
    
    task.delay(10,function()
        if h then h:Destroy() end
    end)
end

-- CHECK ADMIN
local function IsAdmin(p)
    for _,id in ipairs(AdminList) do
        if p.UserId == id then return true end
    end
end

-- SERVER HOP
local function ServerHop()
    local placeId = game.PlaceId
    
    local servers = Safe(function()
        return HttpService:JSONDecode(
            game:HttpGet("https://games.roblox.com/v1/games/"..placeId.."/servers/Public?sortOrder=Asc&limit=100")
        )
    end)
    
    if servers and servers.data then
        for _,v in pairs(servers.data) do
            if v.playing < v.maxPlayers then
                TeleportService:TeleportToPlaceInstance(placeId, v.id)
                break
            end
        end
    end
end

-- CHARACTER TRACK
local function TrackChar(p)
    p.CharacterAdded:Connect(function(char)
        if NotifyRespawn then
            Notify("Respawn",p)
            ESP(p,Color3.fromRGB(255,255,0))
        end
        
        local hum = char:WaitForChild("Humanoid",5)
        if hum then
            hum.Died:Connect(function()
                if NotifyDeath then
                    Notify("Died",p)
                    ESP(p,Color3.fromRGB(255,0,0))
                end
            end)
        end
    end)
end

