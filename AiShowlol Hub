-- AI LOBBY DETECT (STABLE)
--====================================================
local function IsLobby()
    local score = 0

    if #Players:GetPlayers() <= 1 then score += 2 end
    if workspace:FindFirstChild("Lobby") then score += 2 end
    if workspace:FindFirstChild("Waiting") then score += 1 end
    if not workspace:FindFirstChildOfClass("Terrain") then score += 2 end
    if #workspace:GetChildren() < 6 then score += 1 end

    return score >= 4
end

