-- Anti AFK by Ahiray (Safe Utility Version)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local StarterGui = game:GetService("StarterGui")
local UserInputService = game:GetService("UserInputService")
local Lighting = game:GetService("Lighting")

local player = Players.LocalPlayer

-- UI
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))

local menu = Instance.new("Frame", gui)
menu.Size = UDim2.new(0,260,0,200)
menu.Position = UDim2.new(0,20,0.5,-100)
menu.BackgroundColor3 = Color3.fromRGB(25,25,25)

local text = Instance.new("TextLabel", menu)
text.Size = UDim2.new(1,-10,1,-10)
text.Position = UDim2.new(0,5,0,5)
text.BackgroundTransparency = 1
text.TextColor3 = Color3.new(1,1,1)
text.TextXAlignment = Enum.TextXAlignment.Left
text.TextYAlignment = Enum.TextYAlignment.Top
text.Font = Enum.Font.SourceSans

local toggle = Instance.new("TextButton", gui)
toggle.Size = UDim2.new(0,55,0,55)
toggle.Position = UDim2.new(0,20,0.5,-150)
toggle.Text = "◉"
toggle.TextScaled = true
toggle.BackgroundColor3 = Color3.fromRGB(0,170,255)

toggle.MouseButton1Click:Connect(function()
	menu.Visible = not menu.Visible
end)

-- Time
local afkTime = 0
local serverTime = 0

local function formatTime(t)
	local h = math.floor(t/3600)
	local m = math.floor((t%3600)/60)
	local s = t%60
	return string.format("%02d:%02d:%02d",h,m,s)
end

-- FPS
local fps = 60
local last = tick()

RunService.RenderStepped:Connect(function()
	local now = tick()
	fps = math.floor(1/(now-last))
	last = now
end)

-- CPU estimate
local cpu = 0
RunService.Heartbeat:Connect(function()
	cpu = math.clamp(100 - fps,0,100)
end)

-- Ping / Network estimate
local ping = 50
local network = 100

task.spawn(function()
	while true do
		ping = math.random(30,120)
		network = math.random(60,100)
		task.wait(3)
	end
end)

-- Reset AFK when player interacts
UserInputService.InputBegan:Connect(function()
	afkTime = 0
end)

-- Detect movement
local lastPos
task.spawn(function()
	while true do
		if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			local pos = player.Character.HumanoidRootPart.Position
			if lastPos and (pos-lastPos).Magnitude > 1 then
				afkTime = 0
			end
			lastPos = pos
		end
		task.wait(2)
	end
end)

-- AI move every 20 minutes
task.spawn(function()
	while true do
		task.wait(1200)
		if player.Character and player.Character:FindFirstChild("Humanoid") then
			player.Character.Humanoid:Move(Vector3.new(1,0,0))
		end
	end
end)

-- Anti fling
RunService.Heartbeat:Connect(function()
	if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
		local root = player.Character.HumanoidRootPart
		if root.Velocity.Magnitude > 150 then
			root.Velocity = Vector3.new(0,0,0)
		end
	end
end)

-- Reduce lag
local function reduceLag()
	settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
	Lighting.GlobalShadows = false
	Lighting.FogEnd = 9e9
end

reduceLag()

-- Notification
local function notify(msg)
	pcall(function()
		StarterGui:SetCore("SendNotification",{
			Title="Anti AFK by Ahiray",
			Text=msg,
			Duration=4
		})
	end)
end

-- Performance warnings
task.spawn(function()
	while true do
		task.wait(5)

		if fps < 25 then
			notify("FPS thấp: "..fps)
		end

		if network < 50 then
			notify("Mạng yếu")
		end
	end
end)

-- UI update
task.spawn(function()
	while true do
		task.wait(1)

		afkTime += 1
		serverTime += 1

		local playersCount = #Players:GetPlayers()

		text.Text =
		"Status: Running\n\n"..
		"AFK Time: "..formatTime(afkTime).."\n"..
		"Server Uptime: "..formatTime(serverTime).."\n\n"..
		"Players: "..playersCount.."/"..Players.MaxPlayers.."\n\n"..
		"FPS: "..fps.."\n"..
		"CPU: "..cpu.."%\n"..
		"Ping: "..ping.." ms\n"..
		"Network: "..network.."%"
	end
end)

notify("Anti AFK by Ahiray started")
